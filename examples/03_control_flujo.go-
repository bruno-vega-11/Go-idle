// Ejemplo 3: control de flujo (if / else dentro de un for)
// Muestra: sentencia if-else, operadores relacionales (==, <),
// y el uso de continue/break implicito via la estructura del bucle.
func main() {
    var i int = 0;
    for i = 0; i < 10; i = i + 1 {
        if i == 5 {
            println(100);
        } else {
            println(i);
        };
    };
};
